# Copy to .env.prod and fill in values — never commit .env.prod
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# Postgres
POSTGRES_PASSWORD=
APP_USER_PASSWORD=

# Auth
JWT_SECRET_KEY=
INTERNAL_SERVICE_SECRET=

# Pipeline — Ollama cloud
OLLAMA_ENDPOINT=https://ollama.com/api
OLLAMA_API_KEY=

# Pipeline — Google embeddings (gemini-embedding-001)
GOOGLE_API_KEY=

# Cloudflare tunnel (for DB access from local dev)
CLOUDFLARE_TUNNEL_TOKEN=

# Cloudflare API token for DNS-01 wildcard cert (Zone:DNS:Edit on mistaike.ai)
CLOUDFLARE_API_TOKEN=

# Portainer Business license key + GitHub OAuth
PORTAINER_LICENSE_KEY=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Image tags (set by CI deploy)
API_IMAGE_TAG=latest
MCP_IMAGE_TAG=latest
UI_IMAGE_TAG=latest
BACKEND_IMAGE_TAG=latest
